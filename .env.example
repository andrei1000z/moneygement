# =====================================================================
# Banii — variabile de mediu
# Copiază în `.env.local` (dev) sau setează în Vercel → Project Settings
# → Environment Variables (production). NU committa `.env.local` în git
# (e deja în .gitignore).
# =====================================================================

# --- Site URL (link-uri invite, callback bancar, push) ---------------
# Dev: http://localhost:3000
# Prod: https://domeniul-tau.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase --------------------------------------------------------
# Le iei din: Supabase Dashboard → Project Settings → API.
# Anon key = public (browser-safe). Service role = SECRET (server-only).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE-WITH-YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="REPLACE-WITH-YOUR-SERVICE-ROLE-KEY"

# --- Cron secret (pentru Edge Functions invocate de pg_cron) ---------
# Generează: `openssl rand -hex 32` (sau orice 64 hex chars).
# Aceeași valoare merge și în Supabase Vault ca `app.cron_secret`.
CRON_SECRET=""

# --- AI providers (Vercel AI SDK 6) ----------------------------------
# Anthropic Claude Sonnet 4.6 pentru chat + categorize tier 3 + recap.
# OpenAI text-embedding-3-small pentru pgvector + GPT-4o-mini OCR.
# Groq Llama 3.3 70B pentru voice parse rapid.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY=""

# --- Web Push (VAPID) ------------------------------------------------
# Generează ambele: `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:musattiberiu@gmail.com"

# --- Enable Banking (Open Banking, Romania) --------------------------
# Înregistrează aplicația la https://enablebanking.com:
#   1. Generează RSA keypair: `openssl genrsa -out private.pem 2048`
#                              `openssl rsa -in private.pem -pubout -out public.pem`
#   2. Convertește private la PKCS#8:
#      `openssl pkcs8 -topk8 -in private.pem -out private-pkcs8.pem -nocrypt`
#   3. Upload public.pem în Enable Banking dashboard.
#   4. Copiază APPLICATION_ID + KEY_ID din dashboard.
#   5. Pentru Vercel: paste PRIVATE_KEY ca o linie cu \n escape-uite,
#      SAU folosește `vc env add ENABLE_BANKING_PRIVATE_KEY < private-pkcs8.pem`.
ENABLE_BANKING_APPLICATION_ID=""
ENABLE_BANKING_KEY_ID=""
ENABLE_BANKING_PRIVATE_KEY=""
