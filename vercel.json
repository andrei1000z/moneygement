{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "next build --webpack",
  "framework": "nextjs",
  "regions": ["fra1"],
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=4096"
    }
  },
  "functions": {
    "src/app/api/ai/chat/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ai/parse-receipt/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/ai/parse-voice/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/fx/historical/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/banking/start-auth/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/banking/callback/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
